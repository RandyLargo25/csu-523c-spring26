geom_point(size=3) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
labs(
title = "Predicted vs Acutal Log Transformed Lees Ferry Flow",
x = "Predicted Log",
y = "Acutal Log",
color = "Dominant Season"
) +
theme_minimal()
#| eval: true
ggplot(aug, aes(x = .resid)) +
geom_histogram(binwidth = 0.1, fill = "skyblue", color = "black", alpha = 0.7) +
geom_violin(xintercept = 0, linetype = "dashed", color = "red", size = 1) +
labs(
title = "Histogram of Model Residuals",
x = "Residual",
y = "Count"
) +
theme_minimal()
#| eval: true
ggplot(aug, aes(x = .resid)) +
geom_histogram(binwidth = 0.1, fill = "skyblue", color = "black", alpha = 0.7) +
geom_vline(xintercept = 0, linetype = "dashed", color = "red", size = 1) +
labs(
title = "Histogram of Model Residuals",
x = "Residual",
y = "Count"
) +
theme_minimal()
