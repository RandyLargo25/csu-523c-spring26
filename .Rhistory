if (!requireNamespace("pacman", quietly = TRUE)) install.packages("pacman")
pacman::p_load(
tidyverse,
dataRetrieval,
zoo,
patchwork,
flextable,
lubridate,
broom,
ggplot2,
stringr,
maps
)
#| label: data-pull
#| cache: true
gauges <- tribble(
~site_no,     ~name,                           ~state,
"09380000",   "Colorado R at Lees Ferry",      "AZ",
"09163500",   "Colorado R near CO-UT border",  "CO",
"09085000",   "Colorado R at Glenwood Springs","CO",
"09306500",   "White R near Watson",           "UT",
"09379500",   "San Juan R near Bluff",         "UT",
"09402500",   "Little Colorado R near Cameron","AZ",
"09423000",   "Colorado R below Hoover Dam",   "NV"
)
raw <- readNWISdv(
siteNumbers = gauges$site_no,
parameterCd = "00060",
startDate   = "1980-01-01",
endDate     = "2023-12-31"
) |>
renameNWISColumns() |>              # renames X_00060_00003 → Flow
left_join(gauges, by = "site_no") |>
select(site_no, name, state, Date, Flow)
glimpse(raw)
my.date <- as.Date("2023-09-30")
as.Date(my.date)
class(my.date)
flow_data <- raw |>
arrange(site_no, Date) |>
group_by(site_no) |>
mutate(flow_delta = Flow - lag(Flow))
glimpse(flow_data)
filtered_data <- flow_data |>
filter(Date == my.date)
table1_data <- filtered_data |>
slice_max(order_by = Flow, n = 5) |>
mutate(Flow = round(Flow, 0))
table1 <- table1_data |>
select(name, state, Flow) |>
flextable() |>
set_header_labels(name="Gauge", state = "State",Flow="Dischage (cfs)") |>
set_caption(paste("Top 5 Gauges by Dischage on",my.date)) |>
autofit()
glimpse(table1)
table1
table2_data <- filtered_data |>
slice_max(order_by = flow_delta, n = 5) |>
mutate(flow_delta = round(flow_delta, 0))
table2 <- table2_data |>
select(name, state, flow_delta) |>
flextable() |>
set_header_labels(name = "Gauge", state = "State", flow_delta = "Change in Flow (cfs)") |>
set_caption(paste("top 5 Guages by Flow Increase on", my.date))
glimpse(table2)
table2
#| label: site-meta
#| cache: true
site_meta <- readNWISsite(gauges$site_no) |>
select(
site_no,
drain_area_va,   # drainage area in square miles
huc_cd,          # 8-digit HUC watershed code
dec_lat_va,      # latitude
dec_long_va      # longitude
)
# Is site_no actually unique? If any row shows n > 1, the join will duplicate rows
site_meta |> count(site_no) |> filter(n > 1)
flow_joined_data <- flow_data |>
left_join(site_meta, by = "site_no")
glimpse(flow_joined_data)
nrow(flow_joined_data) == nrow(flow_data)
sum(is.na(flow_joined_data$drain_area_va))
sum(is.na(flow_joined_data$huc_cd))
sum(is.na(flow_joined_data$dec_lat_va))
sum(is.na(flow_joined_data$dec_long_va))
summary(flow_joined_data)
flow_joined_data |>
filter(site_no == "09380000") |>
slice(1:5)
flow_joined_data <- flow_joined_data |>
mutate(flow_per_sqmi = Flow / drain_area_va)
?flextable
daily_snapshot <- flow_joined_data |>
filter(Date == my.date)
daily_snapshot <- daily_snapshot |>
mutate(raw_rank = rank(-Flow,ties.method = "min"),
normalized_rank = rank(-flow_per_sqmi, ties.method = "min"))
rank_table <- daily_snapshot |>
select(name, Flow, drain_area_va, flow_per_sqmi, raw_rank, normalized_rank) |>
arrange(raw_rank) |>
mutate(Flow=round(Flow, 0),
flow_per_sqmi=round(flow_per_sqmi, 2)) |>
flextable() |>
set_header_labels(names="Gauge", Flow="Discharge (csf)",
drain_area_va="Drainage Area (mi^2)",
flow_per_sqmi="Normalized Flow (cfs/mi^2)",
raw_rank="Raw Rank",
normalized_rank="Normailzed Rank") |>
set_caption(paste("Raw and Normalized Ranking on", my.date)) |>
autofit()
rank_table
flow_joined_data <- flow_joined_data |>
arrange(site_no, Date) |>
group_by(site_no) |>
mutate(flow_7d = rollmean(Flow, k = 7, fill = NA, align = "right")) |>
ungroup()
low_flow_thresholds <- flow_joined_data |>
filter(Date >= as.Date("1980-01-01") & Date <= as.Date("2010-12-31")) |>
group_by(site_no) |>
summarise(flow_10th = quantile(flow_7d, 0.10, na.rm = TRUE)) |>
ungroup()
flow_joined_data <- flow_joined_data |>
left_join(low_flow_thresholds, by = "site_no") |>
mutate(below_threshold = flow_7d < flow_10th) #?object "flow_10th"not found?
historical_data <- flow_joined_data |>
filter(Date >= as.Date("1980-01-01") & Date <= as.Date("2010-12-31"))
low_flow_thresholds <- historical_data |>
group_by(site_no) |>
summarise(flow_10th = quantile(flow_7d, 0.10, na.rm = TRUE)) |>
ungroup()
flow_joined_data <- flow_joined_data |>
left_join(low_flow_thresholds, by = "site_no") |>
mutate(below_threshold = flow_7d < flow_10th)
flow_joined_data <- flow_joined_data |>
left_join(low_flow_thresholds, by = "site_no") |>
mutate(below_threshold = flow_7d < flow_10th)
flow_joined_data <- flow_joined_data |>
mutate(below_threshold = flow_7d < flow_10th)
historical_data <- flow_joined_data |>
filter(Date >= as.Date("1980-01-01") & Date <= as.Date("2010-12-31"))
low_flow_thresholds <- historical_data |>
group_by(site_no) |>
summarise(flow_10th = quantile(flow_7d, 0.10, na.rm = TRUE)) |>
ungroup()
flow_joined_data <- flow_joined_data |>
left_join(low_flow_thresholds, by = "site_no") |>
mutate(below_threshold = flow_7d < flow_10th)
lees_ferry_data <- flow_joined_data |>
filter(
site_no == "09380000",
Date >= as.Date("2000-01-01"),
Date <= as.Date("2023-12-31")
)
lees_threshold <- lees_ferry_data |>
summarise(threshold = first(flow_10th)) |>
pull(threshold)
ggplot(lees_ferry_data, aes(x = Date, y = flow_7d)) +
geom_ribbon(aes(ymin = 0, ymax = flow_7d, fill = below_threshold)) +
geom_hline(yintercept = lees_threshold,
linetype = "dashed",
color = "blue"
) +
scale_fill_manual(
values = c("TRUE" = "red", "FALSE" = "transparent"),
guide = "none"
) +
labs(
title = "Lees Ferry 7 Day Rolling Mean Discharge",
subtitle = "Red Shading Shows Periods Below 10th Percentile Threshold",
x = "Date",
y = "7 Day Mean Flow"
) +
theme_minimal()
lees_ferry <- flow_joined_data |>
filter(site_no == "09380000")
lees_ferry <- lees_ferry |>
mutate(year = lubridate::year(Date))
annual_counts <- lees_ferry |>
group_by(year) |>
summarize(
below_days = sum(below_threshold, na.rm = TRUE)
) |>
ungroup()
period_summary <- annual_counts |>
mutate(
period = case_when(
year >= 2000 & year <= 2010 ~ "2000-2010",
year >= 2011 & year <= 2023 ~ "2011-2023"
)
) |>
filter(!is.na(period)) |>
group_by(period) |>
summarise(
avg_days_per_year = mean(below_days), #spelling is important!
n_year = n_distinct(year)
)
summary_table <- period_summary |>
mutate(avg_days_per_year = round(avg_days_per_year, 1)) |>
flextable() |>
set_header_labels(
period = "Period",
avg_days_per_year = "Avg. Below Threshold Days/Year",
n_year = "Number of Years"
) |>
set_caption("Lees Ferry Low Flow Days Comparison") |>
autofit()
summary_table
flow_joined_data <- flow_joined_data |>
mutate(
month = month(Date),
water_year = if_else(month >= 10, year(Date) +1, year(Date))
)
annual_summary <- flow_joined_data |>
group_by(site_no, water_year) |>
summarise(
total_discharge = sum(Flow, na.rm = TRUE),
peak_discharge = max(Flow, na.rm = TRUE),
day_below_threshold = sum(below_threshold, na.rm = TRUE)
) |>
ungroup()
annual_summary <- flow_joined_data |>
group_by(site_no, water_year) |>
summarise(
total_discharge = sum(Flow, na.rm = TRUE),
peak_discharge = max(Flow, na.rm = TRUE),
day_below_threshold = sum(below_threshold, na.rm = TRUE)
) |>
ungroup()
flow_joined_data <- flow_joined_data |>
mutate(
month = month(Date),
water_year = if_else(month >= 10, year(Date) +1, year(Date))
)
annual_summary <- flow_joined_data |>
group_by(site_no, water_year) |>
summarise(
total_discharge = sum(Flow, na.rm = TRUE),
peak_discharge = max(Flow, na.rm = TRUE),
day_below_threshold = sum(below_threshold, na.rm = TRUE)
) |>
ungroup()
lees_ferry_annual <- annual_summary |>
filter(site_no == "09380000")
median_total <- median(lees_ferry_annual$total_discharge, na.rm = TRUE)
lees_ferry_annual <- lees_ferry_annual |>
mutate(color = if_else(total_discharge >= median_total, "Above Median", "Below Median"))
ggplot(lees_ferry_annual, aes(x = water_year, y = total_discharge, fill = color)) +
geom_col() +
geom_hline(yintercept = median_total, linetype = "dashed", color = "black") +
scale_fill_manual(values = c("Above Meidan" = "blue", "Below Median" = "red")) +
labs(
title = "Total Annual Discharge at Lees Ferry",
x = "Water Year",
y = "Total Discharge",
fill = "Relative to Median"
) +
theme_minimal()
baseline_stats <- annual_summary |>
filter(water_year >= 1980, water_year <= 2010) |>
group_by(site_no) |>
summarise(
baseline_mean = mean(total_discharge, na.rm = TRUE),
baseline_sd = sd(total_discharge, na.rm = TRUE)
) |>
ungroup()
annual_with_baseline <- annual_summary |>
left_join(baseline_stats, by = "site_no")
annual_with_baseline <- annual_with_baseline |>
mutate(standardized_anomaly = (total_discharge - baseline_mean) / baseline_sd)
annual_with_baseline <- annual_with_baseline |>
left_join(gauges |> select(site_no, name), by = "site_no") |>
mutate(name_wrapped = str_wrap(name, width = 20))
ggplot(annual_with_baseline, aes(x = water_year, y = name_wrapped, fill = standardized_anomaly)) +
geom_tile(color = "white") +
scale_fill_distiller(
palette = "RdBu",
direction = 1,
limits = c(-3, 3),
oob = scales::squish, #spelling is important! "odd"
na.value = "grey80",
name = "Standardized\nAnomaly"
) +
labs(
title = "Basin Wide Standardized Discharge Anomalies",
x = "Water Year",
y = "Gauge"
) +
theme_minimal() +
theme(
axis.text.y = element_text(size = 10),
axis.text.x = element_text(angle = 45, hjust = 1),
panel.grid = element_blank()
)
annual_with_coords <- annual_summary |>
left_join(
site_meta |> select(site_no, dec_lat_va, dec_long_va),
by = "site_no"
)
nrow(annual_with_coords) == nrow(annual_summary)
sum(is.na(annual_with_coords$dec_lat_va))
sum(is.na(annual_with_coords$dec_long_va))
flow_center <- annual_with_coords |>
group_by(water_year) |>
summarise(
weighted_lon = sum(dec_long_va * total_discharge, na.rm = TRUE) / sum(total_discharge, na.rm = TRUE),
weighted_lat = sum(dec_lat_va * total_discharge, na.rm = TRUE) / sum(total_discharge, na.rm = TRUE)
) |>
ungroup()
glimpse(flow_center)
head(flow_center)
us_map <- map_data("state")
west_map <- us_map |>
filter(region %in% c(
"arizona", "california", "colorado", "nevada", "new mexico", "utah", "wyoming"
))
map_plot <- ggplot() +
geom_polygon(
data = west_map,
aes(x = long, y = lat, group = group),
fill = "gray90",
color = "white"
) +
geom_path(
data = flow_center,
aes(x = weighted_lon, y = weighted_lat),
color = "black",
linewidth = 0.8
) +
geom_point(
data = flow_center,
aes(x = weighted_lon, y = weighted_lat, color = water_year),
size = 2
) +
scale_color_gradient(
low = "blue",
high = "red"
) +
coord_fixed(1.3) +
labs(
title = "Flow Weighted Center of Colorado River Basin",
x = "Longitude",
y = "Latitude",
color = "Water Year"
) +
theme_minimal()
lat_plot <- ggplot(flow_center, aes(x = water_year, y = weighted_lat)) +
geom_line(color = "darkblue") +
geom_smooth(method = "lm", se = FALSE, color = "red", linetype = "dashed") +
labs(
title = "Shift in Flow Weighted Lat Over Time",
x = "Water Year",
y = "Weighted Mean Lat"
) +
theme_minimal()
map_plot + lat_plot
#| eval: false
data |> mutate(
month = month(Date),
season = case_when(...),
season = factor(season, levels = c('Snowmelt', 'Monsoon', 'Low-flow', 'Winter'))
)
flow_joined_data <- flow_joined_data |>
mutate(month = month(Date))
flow_joined_data <- flow_joined_data |>
mutate(
season = case_when(
month %in% 4:6 ~ "Snowmelt",
month %in% 7:9 ~ "Monsoon",
month %in% 10:12 ~ "Low-Flow",
month %in% 1:3 ~ "Winter"
)
)
flow_joined_data <- flow_joined_data |>
mutate(
season = factor(season, levels = c("Snowmelt", "Monsoon", "Low-FLow", "Winter"))
)
seasonal_summary <- flow_joined_data |>
group_by(site_no, water_year, season) |>
summarise(
total_seasonal_discharge = sum(Flow, na.rm = TRUE),
runoff_per_sqmi = total_seasonal_discharge / first(drain_area_va)) |>
group_by()
glimpse(seasonal_summary)
head(seasonal_summary)
peak_flows <- flow_joined_data |>
group_by(site_no, water_year) |>
slice_max(flow_7d, n = 1, with_ties = FALSE) |>
ungroup() |>
mutate(
peak_doy = yday(Date) #converting here pk day to day of year
)
lees_peak <- peak_flows |>
filter(site_no == "09380000")
ggplot(lees_peak, aes(x = water_year, y = peak_doy)) +
geom_point(color = "blue") +
geom_smooth(method = "lm", se = FALSE, color = "red", linetype = "dashed") +
labs(
title = "Annual Peak Flow Timing at Lees Ferry",
x = "Water Year",
y = "Peak Day of Year"
) +
theme_minimal()
lees_annual <- annual_summary |>
filter(site_no == "09380000") |>
select(water_year, total_discharge) |>
rename(lees_flow = total_discharge)
glenwood_annual <- annual_summary |>
filter(site_no == "09085000") |>
select(water_year, total_discharge) |>
rename(glenwood_flow = total_discharge)
model_data <- lees_annual |>
left_join(glenwood_annual, by = "water_year")
