filter(site_no == "09380000") |>
group_by(water_year) |>
slice_max(total_seasonal_discharge, n = 1, with_ties = FALSE) |>
select(water_year, season) |>
ungroup()
model_data <- model_data |>
left_join(lees_seasonal, by = "water_year")
glimpse(model_data)
lees_seasonal <- seasonal_summary |>
filter(site_no == "09380000") |>
group_by(water_year) |>
slice_max(total_seasonal_discharge, n = 1, with_ties = FALSE) |>
select(water_year, season) |>
ungroup()
model_data <- model_data |>
left_join(lees_seasonal, by = "water_year")
model_data <- model_data |>
mutate(
